[Unit]
Description=Bitget assistant/command Telegram bot (read-only)
After=network-online.target
Wants=network-online.target

[Service]
WorkingDirectory=/root/bitget_termux_repo
ExecStart=/usr/bin/python3 telegram_command_bot.py
Restart=on-failure
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
