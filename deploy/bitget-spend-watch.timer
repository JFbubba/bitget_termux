[Unit]
Description=Bitget tripwire depense spot reelle (horaire)

[Timer]
# Horaire : detecte tout depassement de la promesse 5$/j en temps quasi-reel. Le cap bloque
# a la source ; ce tripwire est la couche d'OBSERVABILITE independante (alerte, ne corrige rien).
OnBootSec=12min
OnUnitActiveSec=1h
AccuracySec=2min
Persistent=true

[Install]
WantedBy=timers.target
