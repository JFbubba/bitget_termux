# =====================================================================
# .env.example — modele de configuration.
# COPIER en .env puis coller les cles APRES le "=".  Le vrai .env n'est
# JAMAIS versionne (gitignored).
#
#     cp .env.example .env
#     nano .env
#
# Regles : ne jamais committer le .env, ne jamais coller une cle dans un chat.
# Beaucoup de sources sont GRATUITES SANS CLE (voir commentaires) :
# rien a remplir pour celles-la.
# =====================================================================

# --- Bitget (deja en place) : futures, garder en LECTURE SEULE ---
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# --- Telegram ---
# Bot #1 : ALERTES / notifications (utilise par le moteur).
TELEGRAM_BOT_TOKEN=
# Bot #2 : ASSISTANT + commandes (/ask /price /news ...). Si vide -> reutilise le bot #1.
COMMAND_BOT_TOKEN=
# Ton ID Telegram (MEME nombre pour les 2 bots) -> ecris a @userinfobot.
TELEGRAM_CHAT_ID=

# --- LLM : cerveau de l'assistant ---
# Option A (payant, simple) : Claude via Anthropic — mets juste la cle.
ANTHROPIC_API_KEY=
# Option B (GRATUIT, avec outils) : un endpoint OpenAI-compatible.
#   Des que LLM_BASE_URL est rempli, l'assistant l'utilise A LA PLACE d'Anthropic.
#   - Groq (gratuit)   -> cle: console.groq.com/keys
#       LLM_BASE_URL=https://api.groq.com/openai/v1
#       LLM_MODEL=llama-3.3-70b-versatile
#   - Gemini (gratuit) -> cle: aistudio.google.com/apikey
#       LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#       LLM_MODEL=gemini-2.0-flash
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_PROVIDER=

# --- Vision : analyse de charts par IMAGE (Gemini gratuit, separe du LLM texte) ---
# Cle Gemini -> aistudio.google.com/apikey (commence par AIza). Defauts: gemini-2.0-flash.
VISION_API_KEY=
VISION_MODEL=
VISION_BASE_URL=

# =====================================================================
# DONNEES MARCHE / AGREGATEURS
# SANS cle (rien a faire) : Binance public, Bitget public, CoinPaprika,
#   DefiLlama, DexScreener, GeckoTerminal, Jupiter, Kraken/Bybit/OKX public.
# AVEC cle gratuite :
# =====================================================================
COINGECKO_API_KEY=          # demo gratuite -> coingecko.com/api
CRYPTOPANIC_API_TOKEN=      # news + sentiment -> cryptopanic.com/developers/api
FMP_API_KEY=                # crypto + macro + calendrier -> financialmodelingprep.com

# --- Macro (FRED marche SANS cle en CSV ; cle = API JSON optionnelle) ---
FRED_API_KEY=               # optionnel -> fred.stlouisfed.org/docs/api
FINNHUB_API_KEY=            # optionnel -> finnhub.io
ALPHAVANTAGE_API_KEY=       # optionnel -> alphavantage.co
TWELVEDATA_API_KEY=         # optionnel -> twelvedata.com

# =====================================================================
# ON-CHAIN / DEX / SOLANA (detection de tokens, rug, nouveaux mints)
# SANS cle : DexScreener, GeckoTerminal, Jupiter, RPC Solana public,
#   GoPlus Security, Honeypot.is, RugCheck.
# AVEC cle gratuite :
# =====================================================================
BIRDEYE_API_KEY=            # birdeye.so (tier gratuit)
HELIUS_API_KEY=             # helius.dev (RPC + data Solana, tier gratuit)
SOLANA_RPC_URL=             # optionnel : ton endpoint RPC (sinon public)

# =====================================================================
# SOCIAL / SENTIMENT
# =====================================================================
# X / Twitter (compte dedie) — LECTURE seule pour l'analyse de sentiment
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# Farcaster (Neynar, tier gratuit -> neynar.com)
NEYNAR_API_KEY=
# Reddit (app OAuth gratuite -> reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# LunarCrush (metriques sociales, tier gratuit)
LUNARCRUSH_API_KEY=

# =====================================================================
# MARCHES DE PREDICTION
# SANS cle : Polymarket (via prediction-mcp, deja documente).
# =====================================================================
KALSHI_API_KEY=             # optionnel -> kalshi.com

# =====================================================================
# INFRA — NE PAS mettre ici.
# Le token API Hostinger (gestion du VPS) va dans les CREDENTIALS n8n
# (chiffres), PAS dans ce .env de trading.
# =====================================================================
